#!/bin/sh
set -eu

branch_switch=${3:-0}
[ "$branch_switch" = "1" ] || exit 0

repo=$(git rev-parse --show-toplevel 2>/dev/null) || exit 0
cd "$repo" || exit 0

[ -d graphify-out ] || exit 0

if ! command -v uvx >/dev/null 2>&1 && ! command -v graphify >/dev/null 2>&1; then
    exit 0
fi

cache_dir="${XDG_CACHE_HOME:-$HOME/.cache}/mxl-k8s"
mkdir -p "$cache_dir"
log_file="$cache_dir/graphify-hook.log"

(
    echo "[graphify] post-checkout rebuild started at $(date -u +%Y-%m-%dT%H:%M:%SZ)"
    make --no-print-directory graphify-update GRAPHIFY_PATH=.
) >"$log_file" 2>&1 &
